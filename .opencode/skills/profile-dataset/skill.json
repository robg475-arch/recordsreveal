{
  "name": "profile-dataset",
  "version": "1.0.0",
  "description": "Profiles a CSV dataset and recommends which analysis skills to run",
  "author": "RecordsReveal",
  "triggers": [
    "profile dataset",
    "profile csv",
    "analyze what's in",
    "what can I do with"
  ],
  "parameters": {
    "csv_path": {
      "type": "string",
      "description": "Path to the CSV file to profile",
      "required": true
    },
    "output_dir": {
      "type": "string",
      "description": "Directory for profile outputs",
      "default": "analysis_results"
    }
  },
  "outputs": {
    "profile_json": "analysis_results/profile.json",
    "recommendations_json": "analysis_results/recommendations.json"
  },
  "dependencies": []
}
